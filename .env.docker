# Env file for the local Dockerized Postgres started via `docker compose up`.
# Safe to commit — contains no real secrets. Use with `dotenv-cli` if loading
# directly from this file (`npx dotenv -e .env.docker -- <command>`) or copy
# this file to `.env`.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/todays_dollars?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/todays_dollars?schema=public"
DATABASE_ADAPTER="pg"  # Sets Prisma adapter to PrismaPg instead of PrismaNeon
